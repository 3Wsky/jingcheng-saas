PORT=8787
HOST=127.0.0.1
NODE_ENV=production
LOG_LEVEL=info
DATA_DIR=./data
# 公网基址：把上传图片(/uploads/...)拼成绝对 URL，供后台 <img> 与小程序 <image> 访问。
# 必须与小程序 jc-request 的 BASE_URL 一致（含 /sw-api 前缀）。
# 默认即此生产地址；切换域名时改这里。X-Forwarded-* 仅在该值被显式置空时作为兜底。
PUBLIC_BASE_URL=https://ok.xjshunwei.cn/sw-api
PRICE_TAG_DATA_DIR=../digital-price-tag-generator/public/data
# 官网采集器目录（可选，默认从 PRICE_TAG_DATA_DIR 反推）
# OFFICIAL_SCRAPER_DIR=../digital-price-tag-generator

# Admin console.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password
ADMIN_SESSION_SECRET=replace-with-a-random-string-at-least-24-chars
ADMIN_SESSION_MAX_AGE=28800

# CRMEB bridge.
CRMEB_APP_KEY=app_key_69e81b63719a8
CRMEB_DB_HOST=127.0.0.1
CRMEB_DB_PORT=3306
CRMEB_DB_USER=root
CRMEB_DB_PASSWORD=root
CRMEB_DB_NAME=crmeb
CRMEB_DB_PREFIX=eb_
CRMEB_DB_CHARSET=utf8mb4
CRMEB_DB_CONNECTION_LIMIT=5
CRMEB_TOKEN_LEEWAY_SECONDS=60

# AI 生图（gpt-image-2，OpenAI 兼容协议）— 门店礼品 AI 采集 + SN 拍照识别共用
# 未配置时：礼品 AI 采集 / SN AI 识别返回 503；小程序 SN 识别会降级为微信本地 OCR
IMAGE_GEN_BASE_URL=https://api.fastapi.xyz
IMAGE_GEN_API_KEY=replace-with-your-image-api-key
AI_IMAGE_MODEL=gpt-image-2
AI_IMAGE_QUALITY=medium
# SN 拍照识别 — 当前默认仅微信 OCR；后续启用 AI 时再配 SN_VISION_MODEL 并改 SN_VISION_MODE=auto
# SN_VISION_MODE=wechat_only   # 默认，仅微信 OCR
# SN_VISION_MODE=auto          # 微信 OCR 优先，AI 作备选（需 SN_VISION_MODEL）
# SN_VISION_MODE=ai_first      # AI 优先（需 SN_VISION_MODEL + 支持视觉的网关）
# SN_VISION_MODEL=qwen-vl-max  # 单个模型
# SN_VISION_MODELS=qwen-vl-max,qwen-vl-plus,gpt-4-turbo  # 多个模型依次尝试
# 常见可选（取决于你的网关支持）：
#   阿里 DashScope: qwen-vl-max / qwen-vl-plus / qwen2-vl-7b-instruct
#   OpenAI 官方:    gpt-4o-mini / gpt-4-turbo / gpt-4-vision-preview
#   其他网关:       gemini-2.0-flash / claude-3-5-haiku-20241022 / doubao-vision-pro-32k

# 微信小程序凭证（可选，用于 SN 拍照识别的微信 OCR 降级；未配置时自动读 CRMEB eb_system_config）
# WECHAT_MP_APPID=
# WECHAT_MP_SECRET=
