PORT=8787
HOST=127.0.0.1
NODE_ENV=production
LOG_LEVEL=info
DATA_DIR=./data
# 公网基址：把上传图片(/uploads/...)拼成绝对 URL，供后台 <img> 与小程序 <image> 访问。
# 必须与小程序 jc-request 的 BASE_URL 一致（含 /sw-api 前缀）。
# 默认即此生产地址；切换域名时改这里。X-Forwarded-* 仅在该值被显式置空时作为兜底。
PUBLIC_BASE_URL=https://ok.xjshunwei.cn/sw-api
PRICE_TAG_DATA_DIR=../digital-price-tag-generator/public/data
# 官网采集器目录（可选，默认从 PRICE_TAG_DATA_DIR 反推）
# OFFICIAL_SCRAPER_DIR=../digital-price-tag-generator

# Admin console.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password
ADMIN_SESSION_SECRET=replace-with-a-random-string-at-least-24-chars
ADMIN_SESSION_MAX_AGE=28800

# CRMEB bridge.
CRMEB_APP_KEY=app_key_69e81b63719a8
CRMEB_DB_HOST=127.0.0.1
CRMEB_DB_PORT=3306
CRMEB_DB_USER=root
CRMEB_DB_PASSWORD=root
CRMEB_DB_NAME=crmeb
CRMEB_DB_PREFIX=eb_
CRMEB_DB_CHARSET=utf8mb4
CRMEB_DB_CONNECTION_LIMIT=5
CRMEB_TOKEN_LEEWAY_SECONDS=60

# AI 生图（gpt-image-2，OpenAI 兼容协议）— 门店礼品 AI 采集用（可选）
# 未配置时「AI 拍照生成礼品」入口返回 503，不影响其它采集方式
IMAGE_GEN_BASE_URL=https://api.fastapi.xyz
IMAGE_GEN_API_KEY=replace-with-your-image-api-key
AI_IMAGE_MODEL=gpt-image-2
AI_IMAGE_QUALITY=medium
